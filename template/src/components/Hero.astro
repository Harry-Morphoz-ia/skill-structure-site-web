---
// Section d'accueil. Un seul <h1> par page : à n'utiliser qu'une fois.
// Fond sombre + hero.jpg (déposé dans public/assets/images/hero/).
// Option `animated` : active le fond animé « aurora » (sites très animés).
// Option `eyebrow` : petite pastille au-dessus du titre (ex : « Traiteur en Seine-et-Marne »).
import AuroraBackground from './animated/AuroraBackground.tsx';
const { eyebrow, title, subtitle, ctaPrimary, ctaGhost, animated = false } = Astro.props;
---
<section class="hero">
  {animated && <AuroraBackground client:load />}
  <div class="container hero-inner">
    {eyebrow && <p class="hero-eyebrow">{eyebrow}</p>}
    <h1 class="hero-title">{title}</h1>
    {subtitle && <p class="hero-sub">{subtitle}</p>}
    {(ctaPrimary || ctaGhost) && (
      <div class="hero-cta">
        {ctaPrimary && <a href={ctaPrimary.href} class="btn btn-primary">{ctaPrimary.label}</a>}
        {ctaGhost && <a href={ctaGhost.href} class="btn btn-ghost">{ctaGhost.label}</a>}
      </div>
    )}
  </div>
</section>
