---
// Squelette commun à toutes les pages : <head> (SEO) + en-tête + contenu + pied de page.
// Chaque page fournit son `title` et sa `description`.
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SeoSchema from '../components/SeoSchema.astro';
import { site } from '../config/site.js';

const { title, description = site.tagline, current = '' } = Astro.props;
const fullTitle = title ? `${title} · ${site.name}` : `${site.name} · ${site.tagline}`;

// URL canonique : l'adresse "officielle" de la page pour Google (évite qu'une même
// page soit vue en double). Générée dès que `site:` est renseigné dans astro.config.mjs.
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : null;
---
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  {canonical && <link rel="canonical" href={canonical} />}
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <!-- theme-color : à aligner sur --c-primary via /site-construire -->
  <meta name="theme-color" content="#4F46E5" />

  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  {canonical && <meta property="og:url" content={canonical} />}
  <meta property="og:image" content="/assets/images/hero/hero.jpg" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <SeoSchema />
</head>
<body>
  <a href="#contenu" class="skip-link">Aller au contenu</a>
  <Header current={current} />
  <main id="contenu">
    <slot />
  </main>
  <Footer />
</body>
</html>
