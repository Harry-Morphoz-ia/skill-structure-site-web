---
// Squelette commun à toutes les pages : <head> (SEO) + en-tête + contenu + pied de page.
// Chaque page fournit son `title` et sa `description`.
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SeoSchema from '../components/SeoSchema.astro';
import { site } from '../config/site.js';

const { title, description = site.tagline, current = '' } = Astro.props;
const fullTitle = title ? `${title} · ${site.name}` : `${site.name} · ${site.tagline}`;

// URL canonique : l'adresse "officielle" de la page pour Google (évite qu'une même
// page soit vue en double). Générée dès que `site:` est renseigné dans astro.config.mjs.
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : null;
---
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  {canonical && <link rel="canonical" href={canonical} />}
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <!-- theme-color : à aligner sur --c-primary via /site-construire -->
  <meta name="theme-color" content="#4F46E5" />

  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  {canonical && <meta property="og:url" content={canonical} />}
  <meta property="og:image" content="/assets/images/hero/hero.jpg" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet" />

  <SeoSchema />
</head>
<body>
  <a href="#contenu" class="skip-link">Aller au contenu</a>
  <Header current={current} />
  <main id="contenu">
    <slot />
  </main>
  <Footer />

  <script is:inline>
    // Vie du site : fait apparaître les blocs au défilement (zéro dépendance).
    // Respecte prefers-reduced-motion et reste invisible pour les moteurs (contenu déjà dans le HTML).
    document.documentElement.classList.add('js');
    if (!matchMedia('(prefers-reduced-motion: reduce)').matches && 'IntersectionObserver' in window) {
      var cibles = document.querySelectorAll(
        'main .reveal, main .section-title, main .section-lead, main .card, main .grid > *, main .split > *, main .faq-item, main .contact-form'
      );
      var obs = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) { e.target.classList.add('is-visible'); obs.unobserve(e.target); }
        });
      }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
      var compteurs = new Map();
      cibles.forEach(function (el) {
        el.classList.add('reveal');
        var i = compteurs.get(el.parentElement) || 0;   // cascade entre voisins d'un même bloc
        el.style.setProperty('--reveal-delay', Math.min(i * 90, 450) + 'ms');
        compteurs.set(el.parentElement, i + 1);
        obs.observe(el);
      });

      // Chiffres clés : compte de 0 jusqu'à la valeur quand la bande devient visible.
      // Le HTML contient déjà la valeur finale (lisible sans JS et par les moteurs).
      var nombres = document.querySelectorAll('[data-count]');
      if (nombres.length) {
        var obsNum = new IntersectionObserver(function (entries) {
          entries.forEach(function (e) {
            if (!e.isIntersecting) return;
            obsNum.unobserve(e.target);
            var el = e.target;
            var fin = parseFloat(el.getAttribute('data-count'));
            var suffixe = el.getAttribute('data-suffix') || '';
            var depart = null;
            function pas(t) {
              if (depart === null) depart = t;
              var p = Math.min((t - depart) / 1200, 1);
              var facilite = 1 - Math.pow(1 - p, 3);
              el.textContent = Math.round(fin * facilite) + suffixe;
              if (p < 1) requestAnimationFrame(pas);
            }
            requestAnimationFrame(pas);
          });
        }, { threshold: 0.4 });
        nombres.forEach(function (el) { obsNum.observe(el); });
      }
    }
  </script>
</body>
</html>
